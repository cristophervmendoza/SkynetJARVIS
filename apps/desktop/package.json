{
  "name": "@nexa/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "optionalDependencies": {
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.0",
    "active-win": "^8.0.0"
  },
  "build": {
    "appId": "com.nexa.desktop",
    "productName": "Nexa AI Desktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
